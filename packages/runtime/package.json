{
  "name": "@shchilkin/artifact-runtime",
  "version": "0.3.0-alpha.0",
  "description": "Experimental browser runtime for portable Artifact projects",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./rendering": {
      "types": "./dist/rendering.d.ts",
      "default": "./dist/rendering.js"
    },
    "./gpu": {
      "types": "./dist/gpu.d.ts",
      "default": "./dist/gpu.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "pixi.js": "^7.4.3"
  },
  "devDependencies": {
    "typescript": "~6.0.2",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "tag": "experimental"
  }
}
