{
  "name": "@artifact/web",
  "private": true,
  "version": "0.41.2",
  "type": "module",
  "scripts": {
    "build": "npm run build:deps && react-router build",
    "build:ci": "npm run build:deps && react-router build",
    "build:deps": "npm --workspace @shchilkin/artifact-runtime run build && npm --workspace @artifact/shared run build",
    "dev": "npm run build:deps && react-router dev",
    "favicon": "node ../../scripts/generate-favicon.mjs",
    "preview": "vite preview --outDir build/client",
    "typecheck": "npm run build:deps && react-router typegen && tsc",
    "test": "npm run build:deps && vitest run --config vitest.config.ts",
    "test:coverage": "npm run build:deps && vitest run --config vitest.config.ts --coverage --coverage.reporter=text-summary --coverage.reporter=json-summary",
    "test:browser": "npm run build:deps && playwright test -c ../../playwright.config.ts",
    "test:browser:release": "npm run build:deps && PLAYWRIGHT_REUSE_SERVER=0 playwright test -c ../../playwright.config.ts",
    "test:browser:chromium": "npm run build:deps && playwright test -c ../../playwright.config.ts --project=chromium",
    "test:browser:firefox": "npm run build:deps && playwright test -c ../../playwright.config.ts --project=firefox",
    "test:browser:mobile": "npm run build:deps && playwright test -c ../../playwright.config.ts --project=mobile-chromium --project=mobile-webkit",
    "test:browser:webkit": "npm run build:deps && playwright test -c ../../playwright.config.ts --project=webkit"
  },
  "dependencies": {
    "@artifact/shared": "0.0.0",
    "@shchilkin/artifact-runtime": "0.1.0-alpha.3",
    "@react-router/node": "^7.14.2",
    "@xstate/react": "^6.1.0",
    "@xyflow/react": "^12.10.2",
    "better-auth": "^1.6.22",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "isbot": "^5",
    "pixi.js": "^7.4.3",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.2",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "xstate": "^5.31.1"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "@playwright/test": "^1.60.0",
    "@react-router/dev": "^7.14.2",
    "@react-router/serve": "^7.14.2",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "puppeteer": "^24.43.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vite-plugin-tsconfig-paths": "^1.4.1",
    "vitest": "^4.1.5"
  }
}
