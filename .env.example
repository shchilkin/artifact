# React Router / Vite client environment

# Local VPS-like API from docker-compose.local.yml + apps/api.
VITE_AI_API_BASE_URL=http://localhost:4000

# Clerk browser auth. Keep empty to run without account UI.
VITE_CLERK_PUBLISHABLE_KEY=

# Local development only. Must match API_DEV_BEARER_TOKEN in apps/api/.env.
VITE_AI_API_DEV_TOKEN=dev-token
