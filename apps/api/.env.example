NODE_ENV=development
ARTIFACT_BUILD_SHA=development
PORT=4000
WEB_ORIGIN=http://localhost:5173
WEB_ORIGINS=http://localhost:5173

# Database
API_DATABASE_DRIVER=postgres
DATABASE_URL=postgres://artifact:artifact@localhost:5432/artifact

# Queue
API_QUEUE_DRIVER=bullmq
REDIS_URL=redis://localhost:6379

# Auth/session verification
AUTH_JWT_SECRET=local-dev-secret
AUTH_JWT_ISSUER=
AUTH_JWT_AUDIENCE=
API_DEV_BEARER_TOKEN=dev-token
API_BULL_BOARD_ENABLED=true
BETTER_AUTH_SECRET=local-dev-secret
BETTER_AUTH_URL=http://localhost:4000/api/auth
PASSWORD_RESET_LOG_URL=true
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_REPLY_TO=

# Providers
OPENAI_API_KEY=
OPENAI_ADMIN_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_SHADER_MODEL=gpt-5.5
OPENAI_SHADER_TIMEOUT_MS=20000
XAI_API_KEY=
XAI_IMAGE_MODEL=grok-imagine-image-quality

# Storage
ASSET_STORAGE_DRIVER=local
ASSET_STORAGE_DIR=../../.local/artifact-api-storage

# Global provider safety budget (UTC calendar month)
AI_SAFETY_BUDGET_USD=30
