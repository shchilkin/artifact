{
  "name": "@artifact/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "npm --workspace @artifact/shared run build && tsc -p tsconfig.build.json",
    "cleanup:ai": "tsx src/cleanupCli.ts",
    "cleanup:ai:start": "node dist/cleanupCli.js",
    "dev": "deno task --config ../../deno.json api:dev-watch",
    "dev:node-watch": "node scripts/dev-watch.mjs",
    "dev:once": "npm --workspace @artifact/shared run build && tsx src/server.ts",
    "export:job-image": "node scripts/export-job-image.mjs",
    "migrate": "node scripts/migrate.mjs",
    "reconcile:openai-costs": "tsx src/reconcileOpenAiCostsCli.ts",
    "reconcile:openai-costs:start": "node dist/reconcileOpenAiCostsCli.js",
    "migrate:account-tiers:dry-run": "npm --workspace @artifact/shared run build && tsx src/accountTierMigrationCli.ts",
    "smoke": "node scripts/smoke.mjs",
    "start": "node dist/server.js",
    "start:with-migrations": "npm run migrate && npm run start",
    "worker:dev": "npm --workspace @artifact/shared run build && tsx src/worker.ts",
    "worker:start": "node dist/worker.js",
    "typecheck": "npm --workspace @artifact/shared run build && tsc --noEmit -p tsconfig.json",
    "test": "vitest run --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage --coverage.reporter=text-summary --coverage.reporter=json-summary"
  },
  "dependencies": {
    "@artifact/shared": "0.0.0",
    "@bull-board/api": "^7.1.5",
    "@bull-board/express": "^7.1.5",
    "better-auth": "^1.6.22",
    "bullmq": "^5.0.0",
    "express": "^5.2.1",
    "ioredis": "^5.0.0",
    "pg": "^8.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.8.1",
    "typescript": "~6.0.0",
    "vitest": "^4.0.0"
  }
}
