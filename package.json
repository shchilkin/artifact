{
  "name": "album-cover-utils",
  "private": true,
  "version": "0.37.0",
  "type": "module",
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/api",
    "apps/web",
    "packages/shared"
  ],
  "scripts": {
    "favicon": "npm --workspace @artifact/web run favicon",
    "fallow": "fallow --format json --quiet --explain",
    "fallow:audit": "fallow audit --format json --quiet --explain",
    "fallow:dead-code": "fallow dead-code --format json --quiet --explain",
    "fallow:dupes": "fallow dupes --format json --quiet --explain",
    "fallow:health": "fallow health --format json --quiet --explain --score --top 20",
    "dev": "npm --workspace @artifact/web run dev",
    "dev:api": "npm --workspace @artifact/api run dev",
    "dev:infra": "docker compose -f docker-compose.local.yml up -d postgres redis",
    "dev:infra:down": "docker compose -f docker-compose.local.yml down",
    "dev:web": "npm --workspace @artifact/web run dev",
    "dev:worker": "npm --workspace @artifact/api run worker:dev",
    "build": "npm --workspace @artifact/web run build",
    "build:api": "npm --workspace @artifact/api run build",
    "build:ci": "npm --workspace @artifact/web run build:ci",
    "build:shared": "npm --workspace @artifact/shared run build",
    "check": "npm run format:check && npm run lint && npm run typecheck:shared && npm run typecheck && npm run typecheck:api && npm test && npm run test:api",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "lint": "eslint .",
    "prepare": "husky",
    "preview": "npm --workspace @artifact/web run preview",
    "release:verify": "node scripts/verify-release.mjs",
    "turbo:build": "turbo run build --filter=@artifact/shared --filter=@artifact/api --filter=@artifact/web",
    "turbo:check": "turbo run build typecheck test --filter=@artifact/shared --filter=@artifact/api --filter=@artifact/web",
    "turbo:dev": "turbo run dev --filter=@artifact/api --filter=@artifact/web",
    "turbo:typecheck": "turbo run typecheck --filter=@artifact/shared --filter=@artifact/api --filter=@artifact/web",
    "typecheck": "npm --workspace @artifact/web run typecheck",
    "typecheck:api": "npm --workspace @artifact/api run typecheck",
    "typecheck:shared": "npm --workspace @artifact/shared run typecheck",
    "test": "npm --workspace @artifact/web run test",
    "test:api": "npm --workspace @artifact/api run test",
    "test:coverage": "npm run test:coverage:web && npm run test:coverage:api",
    "test:coverage:api": "npm --workspace @artifact/api run test:coverage",
    "test:coverage:web": "npm --workspace @artifact/web run test:coverage",
    "test:browser": "npm --workspace @artifact/web run test:browser --",
    "test:browser:pr": "npm --workspace @artifact/web run test:browser:pr --",
    "test:browser:chromium": "npm --workspace @artifact/web run test:browser:chromium --",
    "test:browser:firefox": "npm --workspace @artifact/web run test:browser:firefox --",
    "test:browser:webkit": "npm --workspace @artifact/web run test:browser:webkit --",
    "test:browser:mobile": "npm --workspace @artifact/web run test:browser:mobile --",
    "test:browser:release": "npm --workspace @artifact/web run test:browser:release --",
    "test:browser:headed": "npm --workspace @artifact/web run test:browser -- --headed",
    "test:browser:install": "playwright install --with-deps chromium firefox webkit",
    "perf:node-editor": "node tests/performance/node-editor.benchmark.mjs"
  },
  "dependencies": {
    "@clerk/react-router": "^3.2.7",
    "@react-router/node": "^7.14.2",
    "three": "^0.184.0",
    "@xstate/react": "^6.1.0",
    "@xyflow/react": "^12.10.2",
    "framer-motion": "^12.38.0",
    "xstate": "^5.31.1",
    "pixi.js": "^7.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@eslint/js": "^10.0.1",
    "@napi-rs/canvas": "^1.0.0",
    "@playwright/test": "^1.60.0",
    "@react-router/dev": "^7.14.2",
    "@react-router/serve": "^7.14.2",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fallow": "^2.88.3",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "puppeteer": "^24.43.0",
    "tailwindcss": "^4.2.4",
    "turbo": "^2.8.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vite-plugin-tsconfig-paths": "^1.4.1",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css}": [
      "biome check --write"
    ],
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  }
}
