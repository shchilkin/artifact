{
  "name": "@artifact/backoffice",
  "private": true,
  "version": "0.41.3",
  "type": "module",
  "scripts": {
    "build": "npm --workspace @artifact/shared run build && react-router build",
    "check": "npm run typecheck && npm run test",
    "dev": "npm --workspace @artifact/shared run build && react-router dev --host 127.0.0.1 --port ${PORT:-4030}",
    "preview": "vite preview --outDir build/client --host 127.0.0.1 --port ${PORT:-4030}",
    "typecheck": "npm --workspace @artifact/shared run build && react-router typegen && tsc",
    "test": "npm --workspace @artifact/shared run build && vitest run --config vitest.config.ts",
    "test:browser": "npm --workspace @artifact/shared run build && playwright test --config playwright.config.ts"
  },
  "dependencies": {
    "@artifact/shared": "0.0.0",
    "@artifact/ui": "0.0.0",
    "@react-router/node": "^7.14.2",
    "better-auth": "^1.6.22",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.2",
    "isbot": "^5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@react-router/dev": "^7.14.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
