{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "git": {
    "deploymentEnabled": {
      "development": false,
      "main": false
    }
  },
  "buildCommand": "npm run build",
  "outputDirectory": "apps/web/build/client",
  "installCommand": "npm install",
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
