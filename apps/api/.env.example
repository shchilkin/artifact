NODE_ENV=development
PORT=4000
WEB_ORIGIN=http://localhost:5173

# Database
API_DATABASE_DRIVER=postgres
DATABASE_URL=postgres://artifact:artifact@localhost:5432/artifact

# Queue
API_QUEUE_DRIVER=bullmq
REDIS_URL=redis://localhost:6379

# Auth/session verification
AUTH_JWT_SECRET=local-dev-secret
AUTH_JWT_ISSUER=
AUTH_JWT_AUDIENCE=
API_DEV_BEARER_TOKEN=dev-token
API_BULL_BOARD_ENABLED=true
BETTER_AUTH_SECRET=local-dev-secret
BETTER_AUTH_URL=http://localhost:4000/api/auth

# Providers
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
XAI_API_KEY=
XAI_IMAGE_MODEL=grok-imagine-image-quality

# Storage
ASSET_STORAGE_DRIVER=local
ASSET_STORAGE_DIR=../../.local/artifact-api-storage

# AI limits
AI_MONTHLY_GENERATION_LIMIT=10
AI_MAX_ACTIVE_JOBS_PER_USER=1
